#!/bin/sh

bindir=@BINDIR@
SCRIPTPATH="$(dirname "$0")"

# If invoked as the unprocessed .in template (e.g. `../scripts/m2k-picocom.in`
# from inside a build dir), use the modemu2k binary in the current directory.
case "$0" in
  *.in)
    if [ -x ./modemu2k ]; then
      bindir=.
      echo "Using ./modemu2k (from .in template) for testing..."
      echo "Press a key to continue..."
      read k
    else
      echo "m2k-picocom.in: run this from a build dir containing ./modemu2k" >&2
      exit 1
    fi
    ;;
  *)
    # If running the configured script from the scripts directory for testing,
    # use the dev binary, not the one installed
    if [ -e $SCRIPTPATH/../modemu2k ]; then
      bindir=$SCRIPTPATH"/.."
      echo "Using $bindir/modemu2k for testing..."
      echo "Press a key to continue..."
      read k
    fi
    ;;
esac

$bindir/modemu2k -e "AT%B0=1%B1=1&W" -c "picocom %s"

cd $savedir

exit $?
