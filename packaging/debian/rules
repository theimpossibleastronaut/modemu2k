#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS=hardening=+all

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure -- \
		--buildtype=release \
		--prefix=/usr \
		-Dstrip=true \
		-Db_sanitize=none \
		-Db_pie=true \
		-Db_lto=true \
		-Dgen-docs=true \
		-Dhelper-scripts=true
